#!/bin/bash
set -e

TRACKED_REPO="$HOME/.config/skillshare/skills/_SafeKeepIt-dot.ai"
CONFIG="$HOME/.config/skillshare/config.yaml"

sync_agents() {
  local agents_src="$TRACKED_REPO/AGENTS.shared.md"
  if [ ! -f "$agents_src" ]; then
    return
  fi
  echo "Syncing AGENTS.shared.md..."
  # Read target paths from config
  grep 'path:.*skills' "$CONFIG" | sed 's|.*path: *||;s|/\.claude/skills.*||;s|/\.ai/skills.*||' | while read -r proj_dir; do
    if [ -d "$proj_dir" ]; then
      cp "$agents_src" "$proj_dir/AGENTS.shared.md"
    fi
  done
}

case "${1:-}" in
  share)
    project="${2:-$(basename "$PWD")}"
    echo "Collecting from $project..."
    /usr/local/bin/skillshare collect "$project" --force
    echo "Syncing to all projects..."
    /usr/local/bin/skillshare sync --force
    sync_agents
    echo "Pushing to GitHub..."
    cd "$TRACKED_REPO"
    git add -A
    if ! git diff --cached --quiet; then
      git commit -m "${3:-Update skills}"
      git pull --rebase || { echo "Conflict detected — resolve in $TRACKED_REPO"; exit 1; }
      git push
      echo "Done — shared and pushed."
    else
      echo "No changes to push to GitHub."
    fi
    ;;
  pull)
    echo "Pulling from GitHub..."
    cd "$TRACKED_REPO"
    git pull --rebase || { echo "Conflict detected — resolve in $TRACKED_REPO"; exit 1; }
    echo "Syncing to all projects..."
    /usr/local/bin/skillshare sync --force
    sync_agents
    echo "Done."
    ;;
  sync)
    /usr/local/bin/skillshare sync --force
    sync_agents
    ;;
  status)
    /usr/local/bin/skillshare status
    ;;
  *)
    echo "Usage: ss <command> [args]"
    echo ""
    echo "  share [project] [message]  Collect, sync, and push to GitHub"
    echo "  pull                       Pull from GitHub and sync to all"
    echo "  sync                       Sync source to all projects"
    echo "  status                     Show current state"
    ;;
esac
